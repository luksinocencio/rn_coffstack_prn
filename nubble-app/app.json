{
  "expo": {
    "name": "nubble-app",
    "slug": "nubble-app",
    "scheme": "com.devmeist3r.nubbleapp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#074C4E"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.devmeist3r.nubbleapp"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#074C4E"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.devmeist3r.nubbleapp"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    }
  }
}
